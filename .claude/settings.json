{
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git branch -v *)",
      "Bash(git branch --list *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(pwd *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(cut *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(which *)",
      "Bash(du *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(diff *)",
      "Bash(awk *)",
      "Bash(sed -n *)",
      "Bash(yarn *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(node *)",
      "Bash(ps *)",
      "Bash(lsof *)",
      "Bash(curl *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue create *)",
      "Bash(gh issue comment *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr create *)",
      "Bash(gh pr checks *)",
      "Bash(gh repo view *)",
      "WebSearch(*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env*)",
      "Read(*.key)",
      "Read(*.pem)",
      "Read(.git/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env*)",
      "Edit(*.key)",
      "Edit(*.pem)",
      "Edit(.git/**)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env*)",
      "Write(*.key)",
      "Write(*.pem)",
      "Bash(git push*--force*)",
      "Bash(git push*-f*)",
      "Bash(git reset*--hard*)",
      "Bash(git branch*-D*)",
      "Bash(rm*-rf*)",
      "Bash(sudo*)",
      "Bash(npm publish*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo archive*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh issue delete*)",
      "Bash(gh release delete*)",
      "Bash(gh run delete*)",
      "Bash(gh workflow delete*)",
      "Bash(gh secret delete*)",
      "Bash(gh gist delete*)"
    ],
    "read": {
      "allow": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.html",
        "*.md",
        "package.json",
        "tsconfig.json",
        "eslint.config.mjs",
        "webpack.renderer.config.js",
        ".prettierrc",
        ".gitignore",
        "CLAUDE.md"
      ],
      "deny": [
        ".env",
        ".env.*",
        "**/.env*",
        "*.key",
        "*.pem",
        "node_modules/**",
        ".git/**",
        "yarn.lock",
        "dist/**",
        "release/**",
        "build/**",
        ".DS_Store"
      ]
    }
  }
}
